{
  "mcpServers": {
    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres"],
      "env": {
        "DATABASE_URL": "postgresql://bidding:bidding@localhost:5432/bidding_db"
      },
      "description": "Query PostgreSQL for bid data, workflow state, audit logs"
    },
    "filesystem-kb": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "./src/kb-vault"],
      "description": "Read/write Obsidian KB vault files"
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": ""
      },
      "description": "GitHub issues, PRs. Run: export GITHUB_PERSONAL_ACCESS_TOKEN=ghp_xxx before starting"
    }
  }
}
