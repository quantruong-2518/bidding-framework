# Aggregated environment template for `docker compose up` from this directory.
# Copy to `.env` and fill in real secrets. Per-service .env.example files
# inside ai-service/ api-gateway/ frontend/ are authoritative for local dev.

# Shared
ANTHROPIC_API_KEY=

# Postgres (matches docker-compose defaults)
POSTGRES_USER=bidding
POSTGRES_PASSWORD=bidding
POSTGRES_DB=bidding_db

# Keycloak bootstrap admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
